model AIChatSession {
  id        String   @id @default(uuid())
  userId    String   @unique
  role      ChatRole @default(USER)
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("ai_chat_sessions")
}



enum ChatRole {
  USER
  MODEL
}
